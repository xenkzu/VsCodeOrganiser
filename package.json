{
  "name": "nette",
  "displayName": "Nette - Smart File Organizer",
  "description": "Automatically organizes DSA practice files into topic folders based on code content: no naming conventions required.",
  "version": "1.0.0",
  "publisher": "YashKaul",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education",
    "Programming Languages"
  ],
  "keywords": [
    "dsa",
    "algorithms",
    "data structures",
    "organizer",
    "workspace",
    "leetcode",
    "competitive programming",
    "file organization",
    "productivity",
    "nette",
    "file organizer",
    "auto sort files",
    "folder structure",
    "code organization",
    "workspace cleaner",
    "auto file management",
    "codeforces",
    "geeksforgeeks",
    "hackerrank",
    "gfg",
    "sorting",
    "binary search",
    "greedy",
    "graphs",
    "linked lists",
    "dynamic programming",
    "memoization",
    "recursion",
    "backtracking",
    "trees"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xenkzu/VsCodeOrganiser"
  },
  "bugs": {
    "url": "https://github.com/xenkzu/VsCodeOrganiser/issues"
  },
  "homepage": "https://github.com/xenkzu/VsCodeOrganiser#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nette.organize",
        "title": "Nette: Organize Workspace"
      },
      {
        "command": "nette.toggleEnabled",
        "title": "Nette: Toggle Enabled"
      },
      {
        "command": "nette.undoLast",
        "title": "Nette: Undo Last Move"
      },
      {
        "command": "nette.setApiKey",
        "title": "Nette: Set Groq API Key"
      },
      {
        "command": "nette.deleteApiKey",
        "title": "Nette: Delete Groq API Key"
      }
    ],
    "configuration": {
      "title": "Nette Organizer",
      "properties": {
        "nette.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Turn Nette on or off. When disabled, files will not be moved or classified."
        },
        "nette.rootDir": {
          "type": "string",
          "default": ".",
          "description": "Root folder for organized files, relative to workspace. Set to '.' or '' to place files directly in the workspace root with no wrapper folder."
        },
        "nette.aiEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable AI fallback using Groq. Run **Nette: Set API Key** command to configure your key securely."
        },
        "nette.debounceDelay": {
          "type": "number",
          "default": 900,
          "minimum": 200,
          "maximum": 5000,
          "description": "Milliseconds to wait after a file save before classifying. Increase if files are being processed multiple times per save."
        },
        "nette.autoNumber": {
          "type": "boolean",
          "default": true,
          "description": "Prefix moved files with the smallest available number in the destination folder (e.g. 0_filename.py)"
        },
        "nette.manualSaveOnly": {
          "type": "boolean",
          "default": true,
          "description": "Only organize files on manual save (Ctrl+S). When enabled, auto-save (on focus change or after delay) will not trigger the organizer."
        },
        "nette.confidenceThreshold": {
          "type": "number",
          "default": 0.55,
          "minimum": 0.1,
          "maximum": 1.0,
          "description": "Minimum confidence score for the heuristic to classify a file without asking AI. Lower = more aggressive classification, higher = more conservative."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}