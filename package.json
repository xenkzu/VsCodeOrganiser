{
  "name": "nette",
  "displayName": "Nette",
  "description": "Automatically organizes DSA practice files into topic folders based on code content: no naming conventions required.",
  "version": "1.0.0",
  "publisher": "YashKaul",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Education"
  ],
  "keywords": [
    "dsa",
    "algorithms",
    "data structures",
    "organizer",
    "workspace",
    "leetcode",
    "competitive programming",
    "file organization",
    "productivity",
    "nette"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/nette"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/nette/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/nette#readme",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dsa-organizer.organize",
        "title": "DSA: Organize Workspace"
      },
      {
        "command": "dsa-organizer.toggleEnabled",
        "title": "DSA: Toggle Enabled"
      },
      {
        "command": "dsa-organizer.undoLast",
        "title": "DSA: Undo Last Move"
      }
    ],
    "configuration": {
      "title": "DSA Organizer",
      "properties": {
        "dsa-organizer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable DSA Organizer."
        },
        "dsa-organizer.rootDir": {
          "type": "string",
          "default": "DSA",
          "description": "Root folder for organized files, relative to workspace. Set to '.' or '' to place files directly in the workspace root with no wrapper folder."
        },
        "dsa-organizer.confidenceThreshold": {
          "type": "number",
          "default": 0.75,
          "description": "Minimum confidence required for automatic move."
        },
        "dsa-organizer.aiEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-based classification."
        },
        "dsa-organizer.aiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Endpoint for AI classifier."
        },
        "dsa-organizer.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce time for file system events in milliseconds."
        },
        "dsa-organizer.autoNumber": {
          "type": "boolean",
          "default": true,
          "description": "Prefix moved files with the smallest available number in the destination folder (e.g. 0_filename.py)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.11",
    "typescript": "^5.3.3"
  }
}